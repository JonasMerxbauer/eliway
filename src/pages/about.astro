---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";

const values = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    title: "Spolehlivost na prvním místě",
    description:
      "Naše systémy jsou páteří řady firem. Tuto odpovědnost bereme vážně — každá aktualizace je důkladně testována, každé nasazení pečlivě naplánováno.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1M15 12a3 3 0 11-6 0 3 3 0 016 0zm-3 9a9 9 0 100-18 9 9 0 000 18z" /></svg>`,
    title: "Řízeno zákazníky",
    description:
      "Trvale zpracováváme podněty uživatelů a schopnosti programu se stále rozvíjejí. Každá funkce existuje proto, že ji reálná firma potřebovala.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L12 12m0 0l4.5-7.795M12 12l-4.5 7.794M12 12l4.5 7.794" /></svg>`,
    title: "Otevřená architektura",
    description:
      "Naše systémy lze přizpůsobit, rozšířit a integrovat. Nevěříme v uzamčená řešení. Váš software by měl růst a měnit se společně s vaší firmou.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
    title: "Osobní přístup",
    description:
      "Obvyklá smlouva zahrnuje telefonickou podporu a pravidelné návštěvy u zákazníka. Podmínky podpory lze přizpůsobit dle individuálních požadavků.",
  },
];
---

<Layout
  title="O nás — Eliway IT — 25+ let podnikového softwaru"
  description="Poznejte příběh Eliway IT od roku 1999. Vyvíjíme podnikový B2B software včetně informačního systému FARAO pro firmy po celé České republice."
  canonicalUrl="/about"
>
  <Navbar currentPath="/about" />

  <!-- ==================== HERO ==================== -->
  <section class="relative py-20 lg:py-32 overflow-hidden">
    <div
      class="absolute bottom-0 left-0 w-96 h-96 bg-amber-500/5 rounded-full blur-[120px]"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <div class="animate-fade-in-up">
            <span
              class="inline-flex items-center gap-2 px-3 py-1.5 text-xs tracking-widest uppercase text-amber-600 border border-amber-500/20 bg-amber-500/5 rounded-sm mb-6"
            >
              Náš příběh
            </span>
          </div>

          <h1
            class="animate-fade-in-up delay-100 font-display text-4xl md:text-5xl lg:text-6xl text-navy-200 leading-[1.1] mb-6"
          >
            Tvoříme software, na kterém
            <em class="text-gradient not-italic">záleží</em>
          </h1>

          <p
            class="animate-fade-in-up delay-200 text-navy-400 text-lg leading-relaxed mb-6"
          >
            Od roku 1999 je Eliway IT výrobcem a dodavatelem podnikového
            softwaru pro české firmy. Naše aplikace pomáhají zejména výrobním a
            montážním firmám při úspěšném řízení v oblasti obchodu, služeb a
            výroby.
          </p>
          <p
            class="animate-fade-in-up delay-300 text-navy-400 text-lg leading-relaxed"
          >
            Věříme v dlouhodobá partnerství. Nedodáváme pouze software —
            poskytujeme řešení na klíč s komplexní podporou, pravidelnými
            návštěvami a neustálým vývojem řízeným zpětnou vazbou uživatelů.
          </p>
        </div>

        <!-- Abstract representation -->
        <div class="animate-fade-in delay-400">
          <div class="relative">
            <!-- Large year display -->
            <div class="text-center">
              <p
                class="font-display text-[120px] lg:text-[160px] text-navy-800/60 leading-none select-none"
              >
                1999
              </p>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <img
                    src="/eliway-logo-icon.png"
                    alt="Eliway IT"
                    class="w-12 h-12 mx-auto mb-4"
                  />
                  <p class="text-xs tracking-[0.3em] uppercase text-navy-500">
                    Založeno
                  </p>
                  <p class="font-display text-xl text-navy-200 mt-1">
                    Praha, CZ
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== VALUES ==================== -->
  <section
    class="relative py-20 lg:py-32 bg-navy-900/50 border-y border-navy-800"
  >
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        label="Čemu věříme"
        title="Principy, které nás <em class='text-gradient not-italic'>vedou</em>"
        description="Náš přístup k vývoji softwaru je zakořeněn v desetiletích úzké spolupráce s reálnými firmami."
      />

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {
          values.map((value, i) => (
            <div
              class="group p-8 bg-white/60 border border-navy-800 hover:border-amber-500/20 transition-all duration-500 rounded-sm shadow-sm"
              data-reveal
              style={`transition-delay: ${i * 100}ms`}
            >
              <div class="w-12 h-12 flex items-center justify-center border border-amber-500/20 bg-amber-500/5 rounded-sm mb-5 text-amber-600 group-hover:border-amber-500/40 transition-colors duration-300">
                <Fragment set:html={value.icon} />
              </div>
              <h3 class="font-display text-xl text-navy-200 mb-3 group-hover:text-amber-600 transition-colors duration-300">
                {value.title}
              </h3>
              <p class="text-navy-400 text-sm leading-relaxed">
                {value.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ==================== WHAT WE OFFER ==================== -->
  <section
    class="relative py-20 lg:py-32 bg-navy-900/50 border-y border-navy-800"
  >
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div data-reveal="left">
          <span
            class="text-xs font-semibold tracking-[0.25em] uppercase text-amber-600 mb-4 block"
            >Model spolupráce</span
          >
          <h2
            class="font-display text-3xl md:text-4xl text-navy-200 leading-tight mb-6"
          >
            Začněte <em class="text-gradient not-italic"
              >bez vstupní investice</em
            >
          </h2>
          <p class="text-navy-400 text-lg leading-relaxed mb-8">
            Nabízíme nový model spolupráce bez počátečních poplatků. Platíte
            pouze měsíční paušál pokrývající kompletní provoz, aktualizace i
            podporu. Vaší jedinou vstupní investicí je čas vašich pracovníků při
            zaškolení.
          </p>
          <Button href="/contact" variant="primary" size="md">
            Zahájit spolupráci
          </Button>
        </div>

        <div data-reveal="right">
          <div class="space-y-4">
            {
              [
                {
                  title: "Bez vstupních poplatků",
                  desc: "Žádné počáteční platby za licence, konfiguraci ani zprovoznění systému",
                },
                {
                  title: "Měsíční paušál",
                  desc: "Předvídatelné náklady zahrnující provoz, nové verze a legislativní úpravy",
                },
                {
                  title: "Kompletní podpora",
                  desc: "Telefonická podpora a pravidelné návštěvy u zákazníka součástí paušálu",
                },
                {
                  title: "Kontinuální vývoj",
                  desc: "Pravidelné aktualizace řízené zpětnou vazbou komunity uživatelů",
                },
              ].map((item, i) => (
                <div class="flex items-start gap-4 p-5 bg-white/60 border border-navy-800 rounded-sm hover:border-amber-500/20 transition-all duration-300 shadow-sm">
                  <span class="font-mono text-xs text-amber-500/40 mt-1">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <div>
                    <h3 class="text-navy-200 font-semibold mb-1">
                      {item.title}
                    </h3>
                    <p class="text-navy-400 text-sm">{item.desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="relative py-20 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-navy-900/30 to-navy-950">
    </div>
    <div
      class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center"
      data-reveal
    >
      <h2
        class="font-display text-3xl md:text-4xl lg:text-5xl text-navy-200 leading-tight mb-6"
      >
        Pojďme tvořit <em class="text-gradient not-italic">společně</em>
      </h2>
      <p class="text-navy-400 text-lg max-w-2xl mx-auto mb-10">
        Ať už potřebujete kompletní implementaci ERP nebo cílené řešení na míru,
        jsme připraveni pomoci.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">
          Kontaktujte nás
        </Button>
        <Button href="/products" variant="outline" size="lg">
          Zobrazit produkty
        </Button>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
