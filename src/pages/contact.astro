---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
---

<Layout
  title="Kontakt – Eliway IT – Požádejte o bezplatnou prezentaci"
  description="Kontaktujte Eliway IT pro bezplatnou prezentaci informačního systému FARAO a dalších B2B softwarových řešení. Kanceláře v Praze a Plzni."
  canonicalUrl="/contact"
>
  <Navbar currentPath="/contact" />

  <!-- ==================== HERO ==================== -->
  <section class="relative py-20 lg:py-28 overflow-hidden">
    <div
      class="absolute top-1/2 -right-32 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-[120px] -translate-y-1/2"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="animate-fade-in-up">
          <span
            class="inline-flex items-center gap-2 px-3 py-1.5 text-xs tracking-widest uppercase text-amber-600 border border-amber-500/20 bg-amber-500/5 rounded-sm mb-6"
          >
            Kontaktujte nás
          </span>
        </div>

        <h1
          class="animate-fade-in-up delay-100 font-display text-4xl md:text-5xl lg:text-6xl text-navy-200 leading-[1.1] mb-6"
        >
          Pojďme mluvit o vaší <em class="text-gradient not-italic">firmě</em>
        </h1>

        <p
          class="animate-fade-in-up delay-200 text-navy-400 text-lg lg:text-xl leading-relaxed"
        >
          Požádejte o bezplatnou, nezávaznou prezentaci. Naši konzultanti
          zanalyzují vaše&nbsp;potřeby a ukážou vám přesně, jak vám naše
          nástroje mohou pomoci.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== CONTACT GRID ==================== -->
  <section class="relative pb-20 lg:pb-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Contact Form (3 cols) -->
        <div class="lg:col-span-3" data-reveal>
          <div
            class="relative bg-white/60 border border-navy-800 p-8 lg:p-10 rounded-sm shadow-sm"
          >
            <div
              class="absolute -top-3 -left-3 w-6 h-6 border-t-2 border-l-2 border-amber-500/40"
            >
            </div>
            <div
              class="absolute -bottom-3 -right-3 w-6 h-6 border-b-2 border-r-2 border-amber-500/40"
            >
            </div>

            <h2 class="font-display text-2xl text-navy-200 mb-2">
              Zašlete nám zprávu
            </h2>
            <p class="text-navy-500 text-sm mb-8">
              Odpovíme do jednoho pracovního dne.
            </p>

            <form class="space-y-6" id="contact-form">
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label
                    for="name"
                    class="block text-xs tracking-[0.15em] uppercase text-navy-500 mb-2"
                    >Jméno a příjmení *</label
                  >
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 bg-navy-900/30 border border-navy-800 text-navy-200 text-sm rounded-sm focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-all duration-300 placeholder:text-navy-600"
                    placeholder="Vaše jméno"
                  />
                </div>
                <div>
                  <label
                    for="company"
                    class="block text-xs tracking-[0.15em] uppercase text-navy-500 mb-2"
                    >Firma</label
                  >
                  <input
                    type="text"
                    id="company"
                    name="company"
                    class="w-full px-4 py-3 bg-navy-900/30 border border-navy-800 text-navy-200 text-sm rounded-sm focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-all duration-300 placeholder:text-navy-600"
                    placeholder="Název firmy"
                  />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label
                    for="email"
                    class="block text-xs tracking-[0.15em] uppercase text-navy-500 mb-2"
                    >E-mail *</label
                  >
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 bg-navy-900/30 border border-navy-800 text-navy-200 text-sm rounded-sm focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-all duration-300 placeholder:text-navy-600"
                    placeholder="vas@email.cz"
                  />
                </div>
                <div>
                  <label
                    for="phone"
                    class="block text-xs tracking-[0.15em] uppercase text-navy-500 mb-2"
                    >Telefon</label
                  >
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 bg-navy-900/30 border border-navy-800 text-navy-200 text-sm rounded-sm focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-all duration-300 placeholder:text-navy-600"
                    placeholder="+420 123 456 789"
                  />
                </div>
              </div>

              <div>
                <label
                  for="interest"
                  class="block text-xs tracking-[0.15em] uppercase text-navy-500 mb-2"
                  >Mám zájem o</label
                >
                <select
                  id="interest"
                  name="interest"
                  class="w-full px-4 py-3 bg-navy-900/30 border border-navy-800 text-navy-200 text-sm rounded-sm focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-all duration-300 appearance-none"
                  style="background-image: url('data:image/svg+xml;charset=US-ASCII,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 20 20%22 fill=%22%23475569%22><path fill-rule=%22evenodd%22 d=%22M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z%22 clip-rule=%22evenodd%22/></svg>'); background-repeat: no-repeat; background-position: right 12px center; background-size: 16px;"
                >
                  <option value="" class="bg-white"
                    >Vyberte produkt nebo službu</option
                  >
                  <option value="farao" class="bg-white"
                    >Informační systém FARAO</option
                  >
                  <option value="service" class="bg-white"
                    >Správa servisu</option
                  >
                  <option value="collection" class="bg-white"
                    >Výkup surovin</option
                  >
                  <option value="planning" class="bg-white"
                    >Řízení zakázek a plánování času</option
                  >
                  <option value="custom" class="bg-white"
                    >Programování na zakázku</option
                  >
                  <option value="other" class="bg-white"
                    >Jiné / Obecný dotaz</option
                  >
                </select>
              </div>

              <div>
                <label
                  for="message"
                  class="block text-xs tracking-[0.15em] uppercase text-navy-500 mb-2"
                  >Zpráva *</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 bg-navy-900/30 border border-navy-800 text-navy-200 text-sm rounded-sm focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-all duration-300 placeholder:text-navy-600 resize-none"
                  placeholder="Popište nám vaše potřeby..."></textarea>
              </div>

              <button
                type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center font-semibold tracking-wide transition-all duration-300 rounded-sm border border-amber-500/40 text-amber-600 hover:bg-amber-500/10 hover:border-amber-500 px-6 py-3 text-sm"
              >
                Odeslat zprávu
              </button>
            </form>

            <!-- Success message (hidden by default) -->
            <div
              id="form-success"
              class="hidden mt-8 p-6 bg-green-500/10 border border-green-500/20 rounded-sm"
            >
              <p class="text-green-600 font-semibold">
                Zpráva byla úspěšně odeslána!
              </p>
              <p class="text-navy-400 text-sm mt-1">
                Ozveme se vám do jednoho pracovního dne.
              </p>
            </div>
          </div>
        </div>

        <!-- Right sidebar: CTA + Offices -->
        <div class="lg:col-span-2 space-y-6" data-reveal="right">
          <!-- Quick contact CTA -->
          <div
            class="p-6 bg-linear-to-br from-amber-500/10 to-amber-500/5 border border-amber-500/20 rounded-sm"
          >
            <h3 class="text-navy-200 font-semibold mb-2">
              Dáváte přednost telefonátu?
            </h3>
            <p class="text-navy-400 text-sm mb-4">
              Naši konzultanti jsou k dispozici v pracovní době pro okamžitou
              konzultaci.
            </p>
            <Button href="tel:+420608483080" class="gap-2">
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                ></path>
              </svg>
              Zavolat
            </Button>
          </div>

          <!-- Prague Office -->
          <div
            class="p-6 bg-white/60 border border-navy-800 rounded-sm hover:border-amber-500/20 transition-all duration-300 shadow-sm"
          >
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-8 h-8 flex items-center justify-center border border-amber-500/20 bg-amber-500/5 rounded-sm"
              >
                <svg
                  class="w-4 h-4 text-amber-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-navy-200 font-semibold">Praha – Sídlo firmy</h3>
            </div>
            <div class="space-y-2 text-sm text-navy-400 ml-11">
              <p>Věšínova 939/4</p>
              <p>Praha 10 – Strašnice</p>
              <div class="pt-2 space-y-1">
                <a
                  href="tel:+420608483080"
                  class="flex items-center gap-2 text-amber-600 hover:text-amber-400 transition-colors"
                >
                  <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                    ></path>
                  </svg>
                  +420 608 483 080
                </a>
                <a
                  href="mailto:stepan@eliwayit.cz"
                  class="flex items-center gap-2 text-amber-600 hover:text-amber-400 transition-colors"
                >
                  <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                    ></path>
                  </svg>
                  stepan@eliwayit.cz
                </a>
              </div>
            </div>
          </div>

          <!-- Pilsen Office -->
          <div
            class="p-6 bg-white/60 border border-navy-800 rounded-sm hover:border-amber-500/20 transition-all duration-300 shadow-sm"
          >
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-8 h-8 flex items-center justify-center border border-amber-500/20 bg-amber-500/5 rounded-sm"
              >
                <svg
                  class="w-4 h-4 text-amber-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-navy-200 font-semibold">Plzeň – Pobočka</h3>
            </div>
            <div class="space-y-2 text-sm text-navy-400 ml-11">
              <p>Částkova 74</p>
              <p>Plzeň</p>
              <div class="pt-2 space-y-1">
                <a
                  href="tel:+420777228930"
                  class="flex items-center gap-2 text-amber-600 hover:text-amber-400 transition-colors"
                >
                  <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                    ></path>
                  </svg>
                  +420 777 228 930
                </a>
                <a
                  href="mailto:plzen@eliwayit.cz"
                  class="flex items-center gap-2 text-amber-600 hover:text-amber-400 transition-colors"
                >
                  <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                    ></path>
                  </svg>
                  plzen@eliwayit.cz
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Simple form submission handler
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("form-success");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    // In production, this would send to your backend
    // For now, show success message
    form.style.display = "none";
    success?.classList.remove("hidden");
  });
</script>
