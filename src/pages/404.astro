---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
---

<Layout
  title="404 — Stránka nenalezena | Eliway IT"
  description="Hledaná stránka nebyla nalezena."
>
  <Navbar />

  <section class="relative min-h-[60vh] flex items-center justify-center">
    <div class="absolute inset-0 opacity-[0.03]">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern
            id="grid404"
            width="60"
            height="60"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M 60 0 L 0 0 0 60"
              fill="none"
              stroke="currentColor"
              stroke-width="0.5"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid404)"></rect>
      </svg>
    </div>

    <div class="relative text-center px-6">
      <p
        class="font-display text-[120px] lg:text-[180px] text-navy-800/60 leading-none select-none mb-[-20px]"
      >
        404
      </p>
      <h1 class="font-display text-3xl md:text-4xl text-navy-200 mb-4">
        Stránka nenalezena
      </h1>
      <p class="text-navy-400 text-lg max-w-md mx-auto mb-8">
        Stránka, kterou hledáte, neexistuje nebo byla přesunuta.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/" variant="primary" size="md">
          Na úvodní stránku
        </Button>
        <Button href="/contact" variant="outline" size="md">
          Kontaktujte nás
        </Button>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
