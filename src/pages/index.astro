            <circle cx="10" cy="10" r="1" fill="currentColor"></circle>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots)"></rect>
      </svg>
    </div>

    <div
      class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center"
      data-reveal
    >
      <h2
        class="font-display text-3xl md:text-4xl lg:text-5xl text-navy-200 leading-tight mb-6"
