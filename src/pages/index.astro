---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import FeatureCard from "../components/FeatureCard.astro";
import Button from "../components/Button.astro";

const industries = [
  {
    icon: "🏗️",
    title: "Montážní firma",
    description:
      "Kompletní vedení zakázky — evidence poptávek, subdodávek, nabídek, objednávek, výkony techniků a správa dokumentů. Ideální pro ocelové konstrukce, zámečnictví a montáže.",
  },
  {
    icon: "🏭",
    title: "Sériová výroba",
    description:
      "Řízení kapacity strojů a výrobních linek, MRP plánování, definice výrobků a sledování režijních nákladů.",
  },
  {
    icon: "📋",
    title: "Zakázková výroba",
    description:
      "Řízení zakázek s kompletní správou dokumentů — výkresy, PDF přílohy, fakturace a vedení skladu.",
  },
  {
    icon: "🏪",
    title: "Obchodní firma",
    description:
      "Kompletní řízení obchodu — katalogy produktů a služeb, sklady, objednávky, fakturace, účetnictví, elektronické bankovnictví a cenová politika.",
  },
  {
    icon: "🔧",
    title: "Servis automobilů",
    description:
      "Evidence vozidel, plánování prohlídek, výkony techniků, normování práce a propojení na systémy výrobců vozidel.",
  },
  {
    icon: "⚡",
    title: "Servis elektro",
    description:
      "Servis bílé techniky, výtahů, klimatizací a tepelných čerpadel s plánováním pravidelné údržby.",
  },
  {
    icon: "🔩",
    title: "Instalatérství",
    description:
      "Evidence zásahů u zákazníka, plánování pravidelných prohlídek, kalkulace, výkony dělníků a plánování času.",
  },
  {
    icon: "♻️",
    title: "Výkup surovin",
    description:
      "Velice jednoduchá obsluha, rychlé odbavení zákazníků. Prodej vykoupených surovin, zhodnocení. Export do EVI.",
  },
  {
    icon: "📦",
    title: "Obchod s paletami",
    description:
      "Evidence různých druhů palet. Opravy, výkup, prodej, vlastní výroba. Propojení na obchodní objednávky.",
  },
];

const stats = [
  { value: "25+", label: "Let zkušeností" },
  { value: "9+", label: "Oborových řešení" },
];
---

<Layout
  title="Eliway IT — Podnikový software a informační systém FARAO"
  description="Eliway IT dodává B2B podniková softwarová řešení. Náš informační systém FARAO pohání výrobní, montážní a obchodní firmy od roku 1999. Bez vstupní investice."
>
  <Navbar currentPath="/" />

  <!-- ==================== HERO ==================== -->
  <section
    class="relative min-h-[85vh] flex flex-col items-center justify-center overflow-hidden"
  >
    <!-- Background grid pattern -->
    <div class="absolute inset-0 opacity-[0.04]">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern
            id="grid"
            width="60"
            height="60"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M 60 0 L 0 0 0 60"
              fill="none"
              stroke="currentColor"
              stroke-width="0.5"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"></rect>
      </svg>
    </div>

    <!-- Gradient orbs -->
    <div
      class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-amber-500/5 rounded-full blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-1/4 -left-32 w-[400px] h-[400px] bg-navy-700/10 rounded-full blur-[100px]"
    >
    </div>

    <!-- Decorative geometric lines -->
    <div
      class="absolute top-16 left-4 xl:top-32 xl:left-16 w-px h-32 bg-linear-to-b from-amber-500/40 to-transparent"
    >
    </div>
    <div
      class="absolute top-16 left-4 xl:top-32 xl:left-16 h-px w-16 bg-linear-to-r from-amber-500/40 to-transparent"
    >
    </div>
    <div
      class="absolute bottom-16 right-4 xl:bottom-32 xl:right-16 w-px h-32 bg-linear-to-t from-amber-500/20 to-transparent"
    >
    </div>
    <div
      class="absolute bottom-16 right-4 xl:bottom-32 xl:right-16 h-px w-16 bg-linear-to-l from-amber-500/20 to-transparent"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-0 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Content -->
        <div>
          <div class="animate-fade-in-up">
            <span
              class="inline-flex items-center gap-2 px-3 py-1.5 text-xs tracking-widest uppercase text-amber-600 border border-amber-500/20 bg-amber-500/5 rounded-sm mb-8"
            >
              <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse"
              ></span>
              Od roku 1999
            </span>
          </div>

          <h1
            class="animate-fade-in-up delay-100 font-display text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-navy-200 leading-[1.1] mb-6"
          >
            Aplikace pro
            <span class="block">
              <em class="text-gradient not-italic">úspěšné</em> řízení
            </span>
            vaší firmy!
          </h1>

          <p
            class="animate-fade-in-up delay-200 text-navy-400 text-lg lg:text-xl leading-relaxed max-w-lg mb-10"
          >
            Podnikové informační systémy na míru pro výrobní, montážní a
            obchodní společnosti. Postaveno na desetiletích praxe.
          </p>

          <div class="animate-fade-in-up delay-300 flex flex-wrap gap-4">
            <Button href="/farao" variant="primary" size="lg">
              Prozkoumat FARAO
              <svg
                class="w-4 h-4 ml-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
            <Button href="/products" variant="outline" size="lg">
              Všechny produkty
            </Button>
          </div>
        </div>

        <!-- Right: Hero image -->
        <div
          class="hidden lg:flex items-center justify-center animate-fade-in delay-400"
        >
          <img
            src="/eliway-intro.png"
            alt="Eliway IT — podnikový software"
            class="w-full max-w-lg"
          />
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="relative md:absolute md:bottom-8 md:left-1/2 md:-translate-x-1/2 flex flex-col items-center gap-2 animate-fade-in delay-700"
    >
      <span class="text-[10px] tracking-[0.3em] uppercase text-navy-600"
        >Posunout</span
      >
      <div
        class="w-px h-8 bg-linear-to-b from-navy-600 to-transparent animate-pulse"
      >
      </div>
    </div>
  </section>

  <!-- ==================== STATS BAR ==================== -->
  <section class="relative border-y border-navy-800 bg-navy-900/50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12 lg:py-16">
      <div class="grid grid-cols-2 gap-8 lg:gap-12 max-w-2xl mx-auto">
        {
          stats.map((stat, i) => (
            <div
              class="text-center"
              data-reveal
              style={`transition-delay: ${i * 100}ms`}
            >
              <p class="font-display text-4xl lg:text-5xl text-amber-600 mb-2">
                {stat.value}
              </p>
              <p class="text-xs tracking-[0.2em] uppercase text-navy-500">
                {stat.label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT PREVIEW ==================== -->
  <section class="relative py-20 lg:py-32 overflow-hidden">
    <div
      class="absolute top-0 right-0 w-1/2 h-full bg-linear-to-l from-amber-500/2 to-transparent"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <div data-reveal="left">
            <span
              class="text-xs font-semibold tracking-[0.25em] uppercase text-amber-600 mb-4 block"
              >O Eliway IT</span
            >
            <h2
              class="font-display text-3xl md:text-4xl lg:text-5xl text-navy-200 leading-tight mb-6"
            >
              Tvoříme podnikový software <em class="text-gradient not-italic"
                >od roku 1999</em
              >
            </h2>
            <p class="text-navy-400 text-lg leading-relaxed mb-6">
              Jsme výrobcem a dodavatelem ekonomického informačního systému
              FARAO SQL, správce servisu, evidence materiálu a programování na
              zakázku.
            </p>
            <p class="text-navy-400 text-lg leading-relaxed mb-8">
              Nabízíme realizaci zakázky na klíč, kompletní servis včetně údržby
              systému nebo pouze dílčí služby podle potřeby zákazníka. Obvyklá
              smlouva zahrnuje telefonickou podporu a pravidelné návštěvy.
            </p>
            <Button href="/about" variant="outline" size="md">
              Více o nás
              <svg
                class="w-3.5 h-3.5 ml-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
          </div>
        </div>

        <div data-reveal="right" class="relative">
          <!-- Abstract representation of system architecture -->
          <div
            class="relative bg-white/60 border border-navy-800 p-8 lg:p-12 rounded-sm shadow-sm"
          >
            <div
              class="absolute -top-3 -left-3 w-6 h-6 border-t-2 border-l-2 border-amber-500/40"
            >
            </div>
            <div
              class="absolute -bottom-3 -right-3 w-6 h-6 border-b-2 border-r-2 border-amber-500/40"
            >
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {
                [
                  { label: "Obchod", sub: "Řízení" },
                  { label: "Sklad", sub: "Evidence" },
                  { label: "Fakturace", sub: "Doklady" },
                  { label: "Účetnictví", sub: "Finance" },
                  { label: "Výroba", sub: "Kompletace" },
                  { label: "Dokumenty", sub: "Správa" },
                  { label: "Replikace", sub: "Pobočky" },
                  { label: "Bankovnictví", sub: "Elektronické" },
                  { label: "Statistiky", sub: "Reporting" },
                ].map((mod, i) => (
                  <div
                    class={`p-3 sm:p-4 text-center border transition-all duration-500 rounded-sm min-w-0 hover:border-amber-500/40 hover:bg-amber-500/5 ${i === 4 ? "border-amber-500/30 bg-amber-500/5" : "border-navy-800 bg-navy-900/30"}`}
                  >
                    <p
                      class={`font-mono text-xs sm:text-sm font-medium wrap-break-word ${i === 4 ? "text-amber-600" : "text-navy-300"}`}
                    >
                      {mod.label}
                    </p>
                    <p class="text-[10px] text-navy-500 mt-1">{mod.sub}</p>
                  </div>
                ))
              }
            </div>

            <div class="mt-6 pt-6 border-t border-navy-800">
              <div class="flex items-center flex-row-reverse">
                <span class="font-mono text-xs text-navy-600">FARAO SQL</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FLAGSHIP PRODUCT ==================== -->
  <section
    class="relative py-20 lg:py-32 bg-navy-900/50 border-y border-navy-800"
  >
    <div class="absolute inset-0 opacity-[0.02]">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern
            id="diag"
            width="40"
            height="40"
            patternUnits="userSpaceOnUse"
            patternTransform="rotate(45)"
          >
            <line
              x1="0"
              y1="0"
              x2="0"
              y2="40"
              stroke="currentColor"
              stroke-width="0.5"></line>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#diag)"></rect>
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16" data-reveal>
        <span
          class="inline-flex items-center gap-2 px-3 py-1.5 text-xs tracking-widest uppercase text-amber-600 border border-amber-500/20 bg-amber-500/5 rounded-sm mb-6"
        >
          Vlajkový produkt
        </span>
        <h2
          class="font-display text-3xl md:text-4xl lg:text-6xl text-navy-200 leading-tight"
        >
          Informační systém <em class="text-gradient not-italic">FARAO</em>
        </h2>
        <p class="mt-4 text-navy-400 text-lg max-w-2xl mx-auto">
          Komplexní ekonomický informační systém pro řízení malých a středních
          společností — od výroby a montáže přes obchod a skladování po
          fakturaci a účetnictví. Bez vstupní investice.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal>
        {
          [
            {
              icon: "📊",
              title: "Kompletní řízení obchodu",
              desc: "Přehledné vedení obchodního případu s analýzou, integrace skladu, rezervace a sledování zboží na cestě.",
            },
            {
              icon: "🌍",
              title: "Zahraniční obchod",
              desc: "Neomezená agenda obchodování se zahraničím — vícejazyčné doklady, ceny v cizích měnách, export i import.",
            },
            {
              icon: "🏭",
              title: "Výroba a kompletace",
              desc: "Definice výrobků pomocí makrokaret, evidence výrobních čísel celých sestav i jednotlivých komponent.",
            },
            {
              icon: "📋",
              title: "Podpora ISO 9000",
              desc: "Integrovaná správa dokumentů, evidence zodpovědných osob a podpora systému řízení kvality.",
            },
            {
              icon: "🔄",
              title: "Replikace dat",
              desc: "Automatická replikace dat z více vzdálených středisek modemem, internetem či sítí LAN.",
            },
            {
              icon: "⚙️",
              title: "Plně přizpůsobitelný",
              desc: "Otevřená architektura s uživatelsky nastavitelným rozhraním, vlastním řazením sloupců a úpravami na míru.",
            },
          ].map((feature, i) => (
            <div
              class="group p-6 bg-white/60 border border-navy-800 hover:border-amber-500/30 transition-all duration-500 rounded-sm shadow-sm"
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class="text-2xl mb-3">{feature.icon}</div>
              <h3 class="text-navy-200 font-semibold mb-2 group-hover:text-amber-600 transition-colors">
                {feature.title}
              </h3>
              <p class="text-navy-400 text-sm leading-relaxed">
                {feature.desc}
              </p>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-12" data-reveal>
        <Button href="/farao" variant="primary" size="lg">
          Zjistit více o FARAO
          <svg
            class="w-4 h-4 ml-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <!-- ==================== ZERO UPFRONT COST ==================== -->
  <section class="relative py-16 lg:py-24 overflow-hidden">
    <div
      class="absolute inset-0 bg-linear-to-r from-amber-500/4 to-transparent"
    >
    </div>
    <div
      class="absolute top-0 left-0 w-full h-px bg-linear-to-r from-amber-500/0 via-amber-500/20 to-amber-500/0"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-full h-px bg-linear-to-r from-amber-500/0 via-amber-500/20 to-amber-500/0"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div data-reveal="left">
          <span
            class="inline-flex items-center gap-2 px-3 py-1.5 text-xs tracking-widest uppercase text-amber-600 border border-amber-500/20 bg-amber-500/5 rounded-sm mb-6"
          >
            Nový model spolupráce
          </span>
          <h2
            class="font-display text-3xl md:text-4xl lg:text-5xl text-navy-200 leading-tight mb-6"
          >
            Začněte <em class="text-gradient not-italic"
              >bez vstupní investice</em
            >
          </h2>
          <p class="text-navy-400 text-lg leading-relaxed mb-6">
            Žádná počáteční platba za licence ani zprovoznění. Platíte pouze
            pravidelný měsíční paušál, který pokrývá kompletní provoz systému,
            aktualizace i podporu.
          </p>
          <p class="text-navy-400 text-lg leading-relaxed mb-8">
            Vaší jedinou vstupní investicí je čas vašich pracovníků při
            zaškolení. Vše ostatní je součástí měsíčního paušálu.
          </p>
          <Button href="/contact" variant="primary" size="lg">
            Zjistit podmínky
            <svg
              class="w-4 h-4 ml-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </Button>
        </div>

        <div data-reveal="right">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {
              [
                {
                  icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
                  title: "0 Kč na začátku",
                  desc: "Žádné vstupní poplatky za licence ani implementaci",
                },
                {
                  icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`,
                  title: "Měsíční paušál",
                  desc: "Předvídatelné náklady s pravidelnou měsíční platbou",
                },
                {
                  icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
                  title: "Školení v ceně",
                  desc: "Kompletní zaškolení vašeho týmu je součástí",
                },
                {
                  icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.18" /></svg>`,
                  title: "Průběžné aktualizace",
                  desc: "Nové verze a legislativní úpravy automaticky",
                },
              ].map((item, i) => (
                <div
                  class="p-5 bg-white/60 border border-navy-800 hover:border-amber-500/20 transition-all duration-300 rounded-sm shadow-sm"
                  style={`transition-delay: ${i * 80}ms`}
                >
                  <div class="w-10 h-10 flex items-center justify-center border border-amber-500/20 bg-amber-500/5 rounded-sm mb-3 text-amber-600">
                    <Fragment set:html={item.icon} />
                  </div>
                  <h3 class="text-navy-200 font-semibold mb-1">{item.title}</h3>
                  <p class="text-navy-400 text-sm leading-relaxed">
                    {item.desc}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== INDUSTRY SOLUTIONS ==================== -->
  <section class="relative py-20 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        label="Oborová řešení"
        title="Na míru <em class='text-gradient not-italic'>vašemu oboru</em>"
        description="FARAO se přizpůsobí jedinečným požadavkům rozmanitých podnikatelských sektorů. Náš tým nakonfiguruje každé nasazení pro maximální efektivitu."
      />

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          industries.map((industry, i) => (
            <FeatureCard
              icon={industry.icon}
              title={industry.title}
              description={industry.description}
              index={i}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ==================== OTHER PRODUCTS ==================== -->
  <section class="relative py-20 lg:py-32 border-t border-navy-800">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeader
        label="Produktová řada"
        title="Nejen <em class='text-gradient not-italic'>FARAO</em>"
        description="Specializované nástroje, které fungují samostatně nebo se bezproblémově integrují s ekosystémem FARAO."
      />

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {
          [
            {
              title: "Správa servisu",
              desc: "Nejlépe zpracovaný produkt pro řízení servisů na trhu. Evidence vozidel, plánování prohlídek, výkony techniků a propojení se systémy výrobců.",
              href: "/products#service",
              image: "/service.jpg",
              imageAlt: "Servisní nástroje",
            },
            {
              title: "Řízení zakázek a plánování času",
              desc: "Grafikon plánování času pro pracovníky a čety, sledování výdejů dílů, průběžná fakturace a kompletní řízení životního cyklu zakázky.",
              href: "/products#planning",
              image: "/planning.jpg",
              imageAlt: "Plánování zakázek",
            },
            {
              title: "Výkup surovin",
              desc: "Vysoká rychlost zadávání s uživatelsky příjemným řešením. Prodej vykoupených surovin, zhodnocení a export do EVI.",
              href: "/products#collection",
              image: "/collection.jpg",
              imageAlt: "Sběrna surovin",
            },
            {
              title: "Programování na zakázku",
              desc: "Programování databází, specializované aplikace, nástroje pro vyhodnocení dat, doplňky a rozhraní pro integraci s vaším stávajícím informačním systémem.",
              href: "/products#programming",
              image: "/coding.jpg",
              imageAlt: "Programování softwaru",
            },
          ].map((product, i) => (
            <a
              href={product.href}
              class="group relative bg-white/60 border border-navy-800 hover:border-amber-500/30 transition-all duration-500 rounded-sm overflow-hidden shadow-sm"
              data-reveal
              style={`transition-delay: ${i * 100}ms`}
            >
              <div class="absolute top-0 left-0 w-full h-px bg-linear-to-r from-amber-500/0 via-amber-500/30 to-amber-500/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

              <!-- Image strip -->
              <div class="relative h-40 overflow-hidden">
                <img
                  src={product.image}
                  alt={product.imageAlt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-linear-to-t from-white/80 via-white/20 to-transparent"></div>
              </div>

              <!-- Text content -->
              <div class="p-8 lg:p-10 pt-4 lg:pt-5">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <h3 class="font-display text-2xl text-navy-200 group-hover:text-amber-600 transition-colors duration-300">
                    {product.title}
                  </h3>
                  <svg
                    class="w-5 h-5 text-navy-600 group-hover:text-amber-600 group-hover:translate-x-1 transition-all duration-300 shrink-0 mt-1.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"
                    />
                  </svg>
                </div>

                <p class="text-navy-400 text-sm leading-relaxed">
                  {product.desc}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center mt-12" data-reveal>
        <Button href="/products" variant="secondary" size="md">
          Zobrazit všechny produkty
        </Button>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
