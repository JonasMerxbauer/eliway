---
interface Props {
  label: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { label, title, description, centered = true } = Astro.props;
---

<div class:list={["mb-12 lg:mb-16", centered && "text-center"]}>
  <span class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-amber-600 mb-4 relative">
    <span class="relative z-10">{label}</span>
    <span class="absolute -bottom-1 left-0 right-0 h-px bg-amber-500/30"></span>
  </span>
  <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-navy-200 leading-tight mt-2">
    <Fragment set:html={title} />
  </h2>
  {description && (
    <p class:list={[
      "mt-4 text-navy-400 text-lg leading-relaxed",
      centered && "max-w-2xl mx-auto"
    ]}>
      {description}
    </p>
  )}
</div>
