---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  index?: number;
}

const { icon, title, description, href, index = 0 } = Astro.props;
---

<div
  class="group relative p-6 lg:p-8 bg-white/60 border border-navy-800 hover:border-amber-500/40 transition-all duration-500 rounded-sm shadow-sm"
  data-reveal
  style={`transition-delay: ${index * 100}ms`}
>
  <!-- Hover glow effect -->
  <div
    class="absolute inset-0 bg-linear-to-br from-amber-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-sm"
  >
  </div>

  <!-- Corner accent -->
  <div class="absolute top-0 right-0 w-12 h-12 overflow-hidden">
    <div
      class="absolute top-0 right-0 w-px h-8 bg-linear-to-b from-amber-500/40 to-transparent group-hover:h-12 transition-all duration-500"
    >
    </div>
    <div
      class="absolute top-0 right-0 h-px w-8 bg-linear-to-l from-amber-500/40 to-transparent group-hover:w-12 transition-all duration-500"
    >
    </div>
  </div>

  <div class="relative z-10">
    <div class="text-3xl mb-4">{icon}</div>
    <h3
      class="font-display text-xl text-navy-200 mb-3 group-hover:text-amber-600 transition-colors duration-300"
    >
      {
        href ? (
          <a href={href} class="hover:underline underline-offset-4">
            {title}
          </a>
        ) : (
          title
        )
      }
    </h3>
    <p class="text-navy-400 text-sm leading-relaxed">{description}</p>
  </div>

  {
    href && (
      <div class="relative z-10 mt-4">
        <a
          href={href}
          class="inline-flex items-center gap-2 text-xs text-amber-600 font-semibold tracking-wider uppercase hover:gap-3 transition-all duration-300"
        >
          Zjistit více
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            />
          </svg>
        </a>
      </div>
    )
  }
</div>
